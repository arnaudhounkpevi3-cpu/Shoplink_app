# Email Resend recommandé pour envoyer les liens de réinitialisation
# 1. Créez un compte sur https://resend.com
# 2. Récupérez votre API key
# 3. En développement, vous pouvez utiliser onboarding@resend.dev
# 4. En production, utilisez un domaine vérifié dans Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM="ShopLink" <onboarding@resend.dev>

# Email SMTP pour envoyer les liens de réinitialisation
# Exemple Gmail : utilisez un mot de passe d'application, pas le mot de passe normal
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=votre.email@gmail.com
# EMAIL_PASS=mot_de_passe_application
# EMAIL_FROM="ShopLink" <votre.email@gmail.com>
