PORT=5000
# Écoute sur toutes les interfaces (accès mobile en Wi‑Fi) — défaut 0.0.0.0
# HOST=0.0.0.0
# Origines CORS supplémentaires (prod), séparées par des virgules
# CORS_ORIGINS=https://ton-front.vercel.app,https://shoplink.bj
JWT_SECRET=change-me

# MongoDB Atlas (recommandé) — copiez depuis Atlas → Connect → Drivers
# MONGO_URI et MONGODB_URI sont tous deux acceptés
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/shoplink?appName=Cluster0
# Délai max. pour joindre Atlas (ms), optionnel
# MONGODB_SERVER_SELECTION_MS=12000
# Si Mongo est injoignable, l’API démarre quand même en mode JSON (data/state.json)

# FedaPay (optionnel)
# FEDAPAY_SECRET_KEY=sk_sandbox_xxx
# FEDAPAY_PUBLIC_KEY=pk_sandbox_xxx
# FEDAPAY_WEBHOOK_SECRET=wh_sandbox_xxx
# FEDAPAY_ENV=sandbox

# Email (optionnel)
# EMAIL_USER=votre.email@gmail.com
# EMAIL_PASS=mot_de_passe_application
